# Obrigatório — gere um valor seguro para produção (ex.: openssl rand -hex 32)
JWT_SECRET=troque-em-producao-use-uma-string-longa-e-aleatoria

# Opcional — senha do PostgreSQL (default: secret)
DB_PASSWORD=secret

# Opcional — URL do frontend (default: http://localhost)
FRONTEND_URL=http://localhost
