# Obrigatório — gere um valor seguro para produção (ex.: openssl rand -hex 32)
JWT_SECRET=troque-em-producao-use-uma-string-longa-e-aleatoria

# Opcional — senha do PostgreSQL (default: secret)
DB_PASSWORD=secret

# Opcional — URL do frontend (default: http://localhost)
FRONTEND_URL=http://localhost

# Control plane do WPPConnect Cloud Manager.
# Quando definido, o SaaS cria e opera sessões por ele.
WPP_MANAGER_URL=https://cloud-manager.wppconnect.io
WPP_MANAGER_TOKEN=
WPP_ORIGIN=wppconnect-cloud
WPP_DEFAULT_RUNTIME=wppconnect-server
WPP_DEFAULT_PROVIDER=wppconnect

# Fallback legacy para desenvolvimento sem manager.
WPP_SERVER=http://localhost:21465/api
WPP_SECRET_KEY=
