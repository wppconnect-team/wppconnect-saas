# Obrigatório — gere um valor seguro para produção (ex.: openssl rand -hex 32)
JWT_SECRET=troque-em-producao-use-uma-string-longa-e-aleatoria

# Opcional — senha do PostgreSQL (default: secret)
DB_PASSWORD=secret

# Opcional — URL do frontend (default: http://localhost)
FRONTEND_URL=http://localhost

# Runtime interno multi-sessão, gerenciado pelo backend do SaaS.
WPP_SERVER_IMAGE=wppconnect/wppconnect-server:develop
WPP_SERVER=http://runtime:21465/api
WPP_SECRET_KEY=troque-em-producao-runtime-secret
WPP_DEFAULT_PROVIDER=wppconnect
TOKEN_STORE_TYPE=file
