DATABASE_URL=postgres://wppconnect:<senha-do-banco>@localhost:5432/wppconnect
JWT_SECRET=<string-aleatoria-minimo-32-caracteres>
PORT=3000
FRONTEND_URL=http://localhost:5173

# Email do primeiro admin criado automaticamente no primeiro boot (banco vazio)
# As credenciais temporárias serão exibidas no log do container — defina uma senha após o login
ADMIN_EMAIL=admin@localhost

# Control plane do WPPConnect Cloud Manager.
# Quando definido, o backend cria sessão em /api/startSession e
# proxia start/status/qrcode/send-message pelo manager.
WPP_MANAGER_URL=https://cloud-manager.wppconnect.io
WPP_MANAGER_TOKEN=
WPP_ORIGIN=wppconnect-cloud
WPP_DEFAULT_RUNTIME=wppconnect-server
WPP_DEFAULT_PROVIDER=wppconnect

# Fallback legacy sem manager.
WPP_SERVER=http://localhost:21465/api
WPP_SECRET_KEY=<token-secreto-do-servidor-wppconnect>

# Cloudflare Turnstile — obtenha em https://dash.cloudflare.com/?to=/:account/turnstile
# Deixar vazio para desativar a verificação (ex.: ambiente de desenvolvimento)
# Chave de teste (always passes): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# SMTP para envio de e-mails (redefinição de senha)
# Se não configurado, o link será exibido no log do container (stdout)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
