# URL base da API — deixar vazio em desenvolvimento (Vite proxy cuida disso)
# Em produção com domínio próprio, preencher se não usar Nginx proxy
VITE_API_URL=

# Cloudflare Turnstile — obtenha em https://dash.cloudflare.com/?to=/:account/turnstile
# Deixar vazio para desativar o widget (ex.: ambiente de desenvolvimento)
# Chave de teste (always passes): 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=

# Servidor WppConnect
VITE_WPP_SERVER=http://192.168.144.1:21465/api
VITE_WPP_SOCKET=http://192.168.144.1:21465
